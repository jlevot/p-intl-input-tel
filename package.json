{
  "name": "p-intl-input-tel",
  "version": "20.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "jest --coverage",
    "test-ci": "jest --runInBand",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "build_stats": "ng build --stats-json",
    "analyze": "webpack-bundle-analyzer dist/p-intl-input-tel-app/stats.json",
    "build_lib": "ng build p-intl-input-tel",
    "copy-license": "cp ./LICENSE ./dist/p-intl-input-tel",
    "copy-readme": "cp ./README.md ./dist/p-intl-input-tel",
    "copy-files": "npm run copy-license && npm run copy-readme",
    "npm_pack": "npm run copy-files && cd dist/p-intl-input-tel && npm pack",
    "create-link": "cd dist/p-intl-input-tel && npm link",
    "package": "npm run build_lib && npm run npm_pack"
  },
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@primeng/themes": "^21.0.4",
    "@typescript-eslint/types": "^8.0.0",
    "core-js": "^3.32.0",
    "google-libphonenumber": "^3.2.42",
    "primeflex": "^4.0.0",
    "primeng": "^21.1.6",
    "rxjs": "~7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@angular/language-service": "^21.2.12",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.4.9",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "eslint": "^8.51.0",
    "jest": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "ng-packagr": "^21.2.3",
    "prettier": "^3.6.2",
    "ts-node": "~10.9.1",
    "typescript": "^5.8.3",
    "webpack-bundle-analyzer": "^4.9.0"
  }
}
